# Python ML Service Environment
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dociq
DB_USER=dociq
DB_PASS=dociq_secret

KAFKA_BROKERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379

# Groq — free LLM API, no credit card. Get key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

FAISS_INDEX_DIR=/data/faiss_indices
DEBUG=false
