# ============================================================
# DocIQ Environment Configuration
#
# docker compose -f infra/docker-compose.yml ... resolves its
# .env relative to the compose file's own directory, so copy
# this file to infra/.env (NOT to the repo root) and fill in
# real values there:
#
#   cp .env.example infra/.env
#
# NEVER commit infra/.env to version control (it's gitignored).
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dociq
DB_USER=dociq
DB_PASS=change_me_in_production

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── OpenAI ───────────────────────────────────────────────────
# Groq — free LLM API, no credit card. Get key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── JWT (generate a 32-byte random secret) ────────────────────
# openssl rand -hex 32
JWT_SECRET=change_me_to_a_256_bit_random_secret

# ── Upload paths ──────────────────────────────────────────────
UPLOAD_DIR=/uploads
FAISS_INDEX_DIR=/data/faiss_indices

# ── Service URLs ──────────────────────────────────────────────
PYTHON_ML_URL=http://localhost:8000
JAVA_API_URL=http://localhost:8080

# ── Host port overrides (only needed if a default port is already in use) ─
# If `docker compose up` fails with "port is already allocated" or
# "Only one usage of each socket address is normally permitted",
# uncomment and change the relevant line below, then re-run.
# JAVA_API_PORT=8080
# REACT_UI_PORT=3000
# REACT_UI_DEV_PORT=3001   # used only by `make dev` (Vite dev server)
# PYTHON_ML_PORT=8000
# KAFKA_UI_PORT=8091
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# KAFKA_PORT=29092
