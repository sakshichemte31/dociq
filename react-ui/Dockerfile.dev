FROM node:20-alpine
WORKDIR /app

# Deps installed separately so this layer is cached across source edits
COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

# Source is bind-mounted over this in docker-compose.dev.yml for hot reload —
# this COPY just makes the image runnable standalone too.
COPY . .

EXPOSE 3001
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3001"]
